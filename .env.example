# ── Obrigatórias ──────────────────────────────────────────────────────────────
ZENDESK_EMAIL=seu@email.com
ZENDESK_TOKEN=seu-api-token
ZENDESK_SUBDOMAIN=sua-empresa

# ── Opcionais ─────────────────────────────────────────────────────────────────
ZENDESK_TIMEOUT=30
ZENDESK_MAX_RETRIES=3

# ── Ambiente ──────────────────────────────────────────────────────────────────
# development → habilita debug mode do fastmcp e logs detalhados
# production  → desabilita debug (padrão)
ENVIRONMENT=development
LOG_LEVEL=DEBUG
